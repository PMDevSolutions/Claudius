{
  "name": "claudius",
  "version": "0.5.0",
  "description": "Embeddable AI chat widget for PMDS and client sites. React component + standalone script embed, powered by Cloudflare Workers and Claude.",
  "private": true,
  "type": "module",
  "scripts": {
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:dry": "standard-version --dry-run",
    "new-app": "node scripts/create-app.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PMDevSolutions/Claudius.git"
  },
  "keywords": [
    "react",
    "chat-widget",
    "ai-chat",
    "claude",
    "cloudflare-workers",
    "embeddable-widget",
    "typescript"
  ],
  "author": "PAMulligan",
  "license": "MIT",
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "standard-version": "^9.5.0",
    "vitest": "^4.1.0"
  }
}
